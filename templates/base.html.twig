<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}KreativShop
			{% endblock %}
		</title>
		{% block stylesheets %}
			{{ importmap('app') }}
		{% endblock %}
	</head>
	<body class="d-flex flex-column min-vh-100">

		{% include 'partials/_navbar.html.twig' %}
		{# ===== HEADER MOBILE ===== #}
		<div class="ks-mobile-header">
			<a href="{{ path('app_home') }}" class="text-decoration-none">
				<img src="{{ asset('images/LOGO-KreativShop.png') }}" alt="KreativShop" height="32">
			</a>
		</div>

		{# ===== MENU OVERLAY MOBILE ===== #}
		<div class="ks-mobile-menu" id="mobileMenu">
			<a href="{{ path('app_home') }}">Home</a>
			<a href="{{ path('app_news') }}">News</a>
			<a href="{{ path('app_bestsellers') }}">Bestsellers</a>
			<a href="{{ path('app_discover') }}">Discover</a>
			<a href="{{ path('app_contact') }}">Contact</a>
		</div>

		{# ===== NAVBAR BAS MOBILE ===== #}
		<nav class="ks-mobile-nav">
			<button class="ks-burger" id="mobileMenuOpen" aria-label="Menu">
				<span class="ks-burger-line"></span>
				<span class="ks-burger-line"></span>
				<span class="ks-burger-line"></span>
			</button>
		</nav>
		{% include 'partials/_flash.html.twig' %}

		<main class="flex-grow-1"> {% block body %}{% endblock %}
			</main>

			{% include 'partials/_footer.html.twig' %}

			{% block javascripts %}{% endblock %}
		</body>
	</html>
