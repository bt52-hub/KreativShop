{% extends 'base.html.twig' %}

{% block title %}Discover — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="ks-card">
			<p class="text-muted mb-4" style="font-style:italic; font-size:0.9rem">Artist review</p>

			{% for artist in artists %}
				<div class="ks-discover-card">
					<div class="d-flex align-items-center gap-4 flex-grow-1">
						{% if artist.user.avatar %}
							<img src="{{ asset('uploads/avatars/' ~ artist.user.avatar) }}" alt="{{ artist.pseudo }}" class="ks-avatar-img flex-shrink-0">
						{% else %}
							<div class="ks-avatar-placeholder flex-shrink-0">
								<i class="bi bi-person-fill fs-1 text-white"></i>
							</div>
						{% endif %}
						<div>
							<h2 style="font-size:1.3rem; font-weight:700; color:var(--ks-navy)">
								{{ artist.pseudo }}
							</h2>
							<p class="mb-0" style="color:#555; font-size:0.9rem">
								{{ artist.bio ?? 'Artiste sur KreativShop.' }}
							</p>
						</div>
					</div>
					<a href="{{ path('app_artist_show', {id: artist.id}) }}" class="ks-btn-go-artist flex-shrink-0">
						Go to Artist
					</a>
				</div>
			{% else %}
				<p class="text-muted">No artists at the moment.</p>
			{% endfor %}
		</div>
	</div>
{% endblock %}
