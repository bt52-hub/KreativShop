{% extends 'base.html.twig' %}

{% block title %}Order Confirmed — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-5">
		<div class="row justify-content-center">
			<div class="col-md-6">
				<div class="ks-card text-center">
					<h1 class="ks-card-title">Thank you !</h1>
					<p class="mb-3">Your order #{{ order.id }}
						has been confirmed.</p>
					<p class="text-muted mb-4">Total :
						{{ order.totalAmount }}
						€</p>
					<a href="{{ path('app_dashboard_customer') }}" class="ks-btn-secondary">
						Go to my dashboard
					</a>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
