{% extends 'base.html.twig' %}

{% block title %}Login — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-5">
		<div class="row justify-content-center">
			<div class="col-md-5">
				<div class="ks-card">
					<h1 class="ks-card-title">Login</h1>

					{% if error %}
						<div class="ks-flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
					{% endif %}

					<form method="post">
						<input type="email" name="_username" class="ks-input" placeholder="Email" value="{{ last_username }}" autocomplete="email" required>
						<input type="password" name="_password" class="ks-input" placeholder="Password" autocomplete="current-password" required>
						<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

						<button type="submit" class="ks-btn-primary mt-2">LOGIN</button>
					</form>

					<div class="mt-3">
						<a href="{{ path('app_register') }}" class="ks-btn-secondary mt-2">Sign up</a>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
