{% extends 'base.html.twig' %}

{% block title %}New support — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="ks-card">
			<h1 class="ks-card-title">New support for "{{ template.name }}"</h1>

			{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
			{{ form_row(form.type, {'attr': {'class': 'ks-input'}}) }}
			{{ form_row(form.description, {'attr': {'class': 'ks-input'}}) }}
			{{ form_row(form.finalPrice, {'attr': {'class': 'ks-input'}}) }}
			{{ form_row(form.submit) }}
			{{ form_end(form) }}

			<a href="{{ path('app_template_manage', {id: template.artwork.id}) }}" class="ks-btn-secondary mt-3">Cancel</a>
		</div>
	</div>
{% endblock %}
