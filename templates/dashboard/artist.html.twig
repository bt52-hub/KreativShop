{% extends 'base.html.twig' %}

{% block title %}Dashboard Artiste — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="ks-card position-relative">

			<div
				class="row">
				{# Colonne gauche #}
				<div class="col-md-6">
					<div class="d-flex align-items-end gap-3 mb-2">
						<div class="ks-avatar-wrapper">
							{% if user.avatar %}
								<img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar" class="ks-avatar-img">
							{% else %}
								<div class="ks-avatar-placeholder">
									<i class="bi bi-person-fill fs-1 text-white"></i>
								</div>
							{% endif %}
							<a href="{{ path('app_dashboard_artist_edit') }}" class="ks-avatar-modify">(Modify)</a>
						</div>
						<h2 class="ks-dashboard-username">
							{{ user.pseudo is not empty ? user.pseudo : user.firstname }}
						</h2>
						<p class="ks-dashboard-welcome ms-auto text-muted">
							Welcome back on your dashboard
						</p>
					</div>

					<div class="d-flex align-items-center justify-content-between mb-2">
						<h5 class="ks-section-title mb-0">My profile</h5>
						<a href="{{ path('app_dashboard_artist_edit') }}">
							<i class="bi bi-pencil-square fs-5" style="color: var(--ks-navy)"></i>
						</a>
					</div>

					<div class="ks-profile-card">
						{% if user.pseudo %}
							<p class="fw-bold mb-1">{{ user.pseudo }}</p>
						{% endif %}
						<p class="mb-1">{{ user.firstname }}
							{{ user.name }}</p>
						<p class="mb-2 text-muted">{{ user.email }}</p>
						{% if user.address %}
							<p class="mb-0">{{ user.address }}</p>
						{% endif %}
					</div>

					<div class="mt-3">
						<a href="{{ path('app_artwork_new') }}" class="ks-section-title">
							Upload File
						</a>
					</div>
				</div>

				{# Colonne droite #}
				<div class="col-md-6">
					<h5 class="ks-section-title mt-5">My work</h5>
					{% if artworks is defined and artworks is not empty %}
						<div class="row g-2">
							{% for artwork in artworks %}
								<div class="col-6">
									<div class="ks-artwork-thumb">
										{% if artwork.fileUrl %}
											<img src="{{ asset('uploads/artworks/' ~ artwork.fileUrl) }}" alt="{{ artwork.title }}" class="img-fluid rounded">
										{% endif %}
										<p class="mt-1 mb-0 small">{{ artwork.title }}</p>
										<div class="d-flex gap-2">
											<a href="{{ path('app_artwork_edit', {id: artwork.id}) }}" class="small text-primary">Edit</a>
										</div>
									</div>
								</div>
							{% endfor %}
						</div>
					{% else %}
						<p class="text-muted">No creation for the moment.</p>
					{% endif %}
				</div>
			</div>

		</div>
	</div>
{% endblock %}
