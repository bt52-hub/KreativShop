{% extends 'base.html.twig' %}

{% block title %}
	{{ artist.pseudo }}
	— KreativShop
{% endblock %}

{% block body %}
	<div
		class="container py-4">

		{# ===== CARD ARTIST REVIEW ===== #}
		<div class="ks-card mb-4">
			<p class="text-muted mb-3" style="font-size:0.9rem; font-style:italic;">Artist review</p>

			<div
				class="d-flex align-items-center gap-4">
				{# Avatar #}
				<div class="flex-shrink-0">
					{% if artist.user.avatar %}
						<img src="{{ asset('uploads/avatars/' ~ artist.user.avatar) }}" alt="{{ artist.pseudo }}" class="ks-avatar-img">
					{% else %}
						<div class="ks-avatar-placeholder">
							<i class="bi bi-person-fill fs-1 text-white"></i>
						</div>
					{% endif %}
				</div>

				{# Nom + Bio #}
				<div>
					<h1 style="font-size:1.8rem; font-weight:700; color: var(--ks-navy);">
						{{ artist.pseudo }}
					</h1>
					{% if artist.bio %}
						<p class="mt-2" style="color:#555; max-width:600px; line-height:1.6;">
							{{ artist.bio }}
						</p>
					{% endif %}
				</div>
			</div>
		</div>

		{# ===== CARROUSEL OEUVRES ===== #}
		{% if artworks is not empty %}
			<div class="ks-section-bar mb-3">
				<img src="{{ asset('images/picto_logo_ks_B.png') }}" alt="" height="18">
				<em>Work</em>
			</div>

			<div class="position-relative ks-carousel-wrapper">
				<button class="ks-carousel-btn ks-carousel-prev" id="carouselPrev">&#8249;</button>

				<div class="ks-carousel-track" id="carouselTrack">
					{% for artwork in artworks %}
						<div class="ks-carousel-item">
							{% if artwork.fileUrl %}
								<img src="{{ asset('uploads/artworks/' ~ artwork.fileUrl) }}" alt="{{ artwork.title }}">
							{% else %}
								<div class="ks-artwork-placeholder"></div>
							{% endif %}
							<div class="ks-carousel-overlay">
								<span>"{{ artwork.title }}"</span>
								<a href="{{ path('app_product_show', {id: artwork.id}) }}">+ Shop</a>
							</div>
						</div>
					{% endfor %}
				</div>

				<button class="ks-carousel-btn ks-carousel-next" id="carouselNext">&#8250;</button>
			</div>
		{% endif %}

	</div>
{% endblock %}
