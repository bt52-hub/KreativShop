{% extends 'base.html.twig' %}

{% block title %}Manage "{{ artwork.title }}" — KreativShop
{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="ks-card">
			<h1 class="ks-card-title">"{{ artwork.title }}"</h1>

			<div class="d-flex justify-content-between align-items-center mb-3">
				<p class="ks-product-label mb-0">Formats & supports</p>
				<a href="{{ path('app_template_new', {id: artwork.id}) }}" class="ks-btn-outline">
					+ Add format
				</a>
			</div>

			{% if artwork.templates is empty %}
				<p class="text-muted">No format yet. Add one to start selling this artwork.</p>
			{% else %}
				{% for template in artwork.templates %}
					<div class="ks-profile-card mb-3">
						<div class="d-flex justify-content-between align-items-center mb-2">
							<div>
								<strong>{{ template.name }}</strong>
								<span class="text-muted">—
									{{ template.width }}
									x
									{{ template.height }}
									cm</span>
							</div>
							<div class="d-flex gap-2">
								<a href="{{ path('app_template_edit', {id: template.id}) }}" class="small">Edit</a>
								<form method="post" action="{{ path('app_template_delete', {id: template.id}) }}" onsubmit="return confirm('Delete this format and all its products?')">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ template.id) }}">
									<button type="submit" class="text-danger border-0 bg-transparent small">Delete</button>
								</form>
							</div>
						</div>

						<div class="d-flex justify-content-between align-items-center mt-2">
							<p class="mb-0 small text-muted">Available supports :</p>
							<a href="{{ path('app_product_new', {id: template.id}) }}" class="small">+ Add support</a>
						</div>

						{% if template.products is empty %}
							<p class="text-muted small mt-1">No support yet.</p>
						{% else %}
							<ul class="list-unstyled mt-2 mb-0">
								{% for product in template.products %}
									<li class="d-flex justify-content-between align-items-center py-1">
										<span>{{ product.type.value }}
											—
											{{ product.finalPrice }}
											€</span>
										<form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" onsubmit="return confirm('Delete this support?')">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
											<button type="submit" class="text-danger border-0 bg-transparent small">✕</button>
										</form>
									</li>
								{% endfor %}
							</ul>
						{% endif %}
					</div>
				{% endfor %}
			{% endif %}

			<a href="{{ path('app_dashboard_artist') }}" class="ks-btn-secondary mt-3">Back to dashboard</a>
		</div>
	</div>
{% endblock %}
